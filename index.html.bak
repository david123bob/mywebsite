          <div class="flex flex-wrap gap-4 font-label">
            <a class="bg-gradient-to-br from-primary to-indigo-500 text-white px-8 py-4 rounded-full font-bold" href="./assets/resume.pdf" target="_blank" rel="noreferrer">Resume</a>
            <a class="px-8 py-4 rounded-full bg-white/70" href="https://github.com/david123bob" target="_blank" rel="noreferrer">GitHub</a>
            <a class="px-8 py-4 rounded-full bg-white/70" href="https://www.linkedin.com/in/davidhao1" target="_blank" rel="noreferrer">LinkedIn</a>
