<!DOCTYPE html>
<html class="scroll-smooth" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>David Hao | Digital Architect Portfolio</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              primary: "#4648d4",
              secondary: "#6b38d4",
              surface: "#fbf8fc",
              onSurfaceVariant: "#464554",
              inverseSurface: "#303033",
              outlineVariant: "#c7c4d7"
            },
            fontFamily: {
              headline: ["Plus Jakarta Sans"],
              body: ["Inter"],
              label: ["Space Grotesk"]
            }
          }
        }
      };
    </script>
  </head>
  <body class="bg-surface text-slate-900 font-body">
    <nav class="fixed top-0 w-full z-50 bg-white/80 backdrop-blur-xl">
      <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
        <div class="font-headline font-bold text-xl">David Hao</div>
        <div class="hidden md:flex items-center gap-8 font-label">
          <a class="text-primary font-bold" href="#experience">Experience</a>
          <a class="text-slate-600 hover:text-primary" href="#skills">Skills</a>
          <a class="text-slate-600 hover:text-primary" href="#projects">Projects</a>
